{
  "name": "open-erp",
  "version": "1.0.0",
  "description": "Open ERP - Enterprise Resource Planning System",
  "private": true,
  "scripts": {
    "dev": "docker-compose -f docker-compose-dev.yml up --build",
    "dev:detached": "docker-compose -f docker-compose-dev.yml up --build -d",
    "dev:down": "docker-compose -f docker-compose-dev.yml down",
    "dev:logs": "docker-compose -f docker-compose-dev.yml logs -f",
    "dev:restart": "docker-compose -f docker-compose-dev.yml restart",
    "stop": "docker-compose down",
    "clean": "docker-compose down -v --remove-orphans"
  },
  "workspaces": [
    "client",
    "api",
    "auth",
    "messaging"
  ],
  "keywords": [
    "erp",
    "enterprise",
    "management",
    "docker"
  ],
  "author": "",
  "license": "ISC"
}
